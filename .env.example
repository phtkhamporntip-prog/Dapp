# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# SECURITY: Never commit .env files to version control!

# ===========================================
# FIREBASE CONFIGURATION (REQUIRED)
# ===========================================
# Get your Firebase config from: https://console.firebase.google.com
# Project Settings > General > Your apps > SDK setup and configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=onchainweb-dapp.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=onchainweb-dapp
VITE_FIREBASE_STORAGE_BUCKET=onchainweb-dapp.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1032172642498
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_DATABASE_URL=https://onchainweb-dapp-default-rtdb.region.firebasedatabase.app

# ===========================================
# WALLETCONNECT CONFIGURATION (REQUIRED)
# ===========================================
# WalletConnect Project ID (REQUIRED for WalletConnect QR code connections)
# Get your free Project ID from: https://cloud.walletconnect.com
# Without this, WalletConnect feature will NOT work
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ===========================================
# CLOUDFLARE TURN SERVER (OPTIONAL)
# ===========================================
# Cloudflare TURN server for WebRTC connections
# Improves peer-to-peer connection reliability through NAT and firewalls
# Get your credentials from: https://dash.cloudflare.com/
VITE_CLOUDFLARE_TURN_SERVER_NAME=
VITE_CLOUDFLARE_TURN_TOKEN_ID=
VITE_CLOUDFLARE_TURN_API_TOKEN=

# ===========================================
# TELEGRAM INTEGRATION (OPTIONAL)
# ===========================================
# Telegram Bot Integration (for customer service)
# Bot Token from @BotFather on Telegram
VITE_TELEGRAM_BOT_TOKEN=
# Chat ID where messages should be sent (your Telegram user ID or group ID)
VITE_TELEGRAM_CHAT_ID=

# ===========================================
# ADMIN CONFIGURATION (OPTIONAL)
# ===========================================
# Keep admin disabled for public builds by default
VITE_ENABLE_ADMIN=false
# Use private route slugs when enabling admin in production
# Example: /internal-a7x-admin, /internal-a7x-master
VITE_ADMIN_ROUTE=/internal-admin
VITE_MASTER_ADMIN_ROUTE=/internal-master
# Comma-separated allowlisted admin emails (must match Firebase Auth emails)
# Example: phtkhamporntip@gmail.com,admin1@yourdomain.com
VITE_ADMIN_ALLOWLIST=phtkhamporntip@gmail.com

# Optional: wallet-based admin auto redirect (keep false in public deployments)
VITE_ENABLE_ADMIN_WALLET_AUTODETECT=false

# Live support backend URL (Cloudflare Worker)
VITE_CLOUDFLARE_WORKER_URL=

# ===========================================
# CLOUDFLARE WORKERS & DEPLOYMENT (For Deployment Only)
# ===========================================
# These are used for deploying to Cloudflare Workers/Pages
# NOT needed for local development
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
KV_NAMESPACE_ID=
R2_BUCKET_NAME=
R2_ENDPOINT=

# ===========================================
# APP CONFIGURATION (OPTIONAL)
# ===========================================
VITE_APP_NAME=OnchainWeb
VITE_APP_URL=https://onchainweb.app

# ===========================================
# FEATURE FLAGS (OPTIONAL)
# ===========================================
# Enable debug logging in production (NOT recommended)
VITE_ENABLE_DEBUG=false
# Log level: debug, info, warn, error (default: error in production)
VITE_LOG_LEVEL=error

# ===========================================
# DEPOSIT ADDRESSES (REQUIRED FOR PRODUCTION)
# ===========================================
# Override default deposit addresses for supported networks
# If not set, the platform uses hardcoded defaults (NOT RECOMMENDED)
# Get these from your wallet provider or generate secure addresses
VITE_DEPOSIT_BTC=
VITE_DEPOSIT_USDT_TRC20=
VITE_DEPOSIT_USDT_ERC20=

# ===========================================
# SECURITY CONFIGURATION (PRODUCTION REQUIRED)
# ===========================================
# Enable strict security checks in production
VITE_ENABLE_STRICT_AUTH=true
# Rate limit: requests per minute (used in Cloudflare Workers)
VITE_RATE_LIMIT_PER_MINUTE=100

# ===========================================
# FIREBASE ADMIN SDK (FOR WORKERS)
# ===========================================
# Firebase Admin SDK credentials for Cloudflare Workers
# Required for server-side token verification
# Get from Firebase Console > Project Settings > Service Accounts
# These should be set via wrangler secrets in production:
#   wrangler secret put FIREBASE_PRIVATE_KEY
#   wrangler secret put FIREBASE_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ===========================================
# RATE LIMITING (WORKERS CONFIGURATION)
# ===========================================
# Rate limiting configuration for Cloudflare Workers
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_WINDOW_SECONDS=60

# ===========================================
# STORAGE SECURITY (WORKERS)
# ===========================================
# Enable authentication for storage API endpoints
ENABLE_STORAGE_AUTH=true
# Require wallet signature for sensitive operations
REQUIRE_WALLET_SIGNATURE=false

# ===========================================
# DEPRECATED (DO NOT USE)
# ===========================================
# These are kept for backward compatibility only
# MongoDB backend is deprecated - use Firebase instead
# VITE_API_BASE=
# VITE_BACKEND_AUTH_URL=
