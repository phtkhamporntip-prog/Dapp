# Deploy only the frontend app - ignore everything at root first
/*

# Keep essential config files
!vercel.json

# Keep the Onchainweb frontend app directory and all its contents
!Onchainweb
!Onchainweb/**

# Exclude build outputs and dependencies (use explicit paths for compatibility)
node_modules
Onchainweb/node_modules
Onchainweb/dist
Onchainweb/.vercel
Onchainweb/.cache
Onchainweb/.turbo
Onchainweb/.next
Onchainweb/.git

# Documentation files
!README.md
!LICENSE
