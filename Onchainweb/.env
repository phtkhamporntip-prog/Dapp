# ============================================
# SNIPE FRONTEND - Environment Configuration
# ============================================
# Vite requires VITE_ prefix for environment variables
# Replace placeholder values with your actual Firebase credentials

# ===========================================
# FIREBASE CONFIGURATION (PRIMARY BACKEND)
# ============================================
# Get these values from Firebase Console:
# 1. Go to https://console.firebase.google.com
# 2. Select your project
# 3. Click gear icon → Project Settings
# 4. Scroll to "Your apps" → Web app configuration
# 5. Copy the values below

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN_HERE
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET_HERE
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID_HERE
VITE_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID_HERE

# ===========================================
# WALLET CONFIGURATION
# ===========================================
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID_HERE

# ===========================================
# ADMIN GATING (ENABLED FOR ADMIN ACCESS)
# ===========================================
# Enable admin and master routes for secured admin access
VITE_ENABLE_ADMIN=false
# Secret paths for admin routes (leading slash optional)
VITE_ADMIN_ROUTE=/admin
VITE_MASTER_ADMIN_ROUTE=/master-admin
# Comma-separated allowlisted emails (must match Firebase auth emails)
# Add your admin emails here (example: master@admin.onchainweb.app,admin@admin.onchainweb.app)
VITE_ADMIN_ALLOWLIST=
# Master password for automatic account creation (remove in production and use Firebase Console)
VITE_MASTER_PASSWORD=
VITE_MASTER_EMAIL=
VITE_MASTER_USERNAME=
