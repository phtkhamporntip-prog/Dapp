VITE_FIREBASE_MEASUREMENT_ID=G-NVT9RVZW06

# ===========================================
# WALLETCONNECT CONFIGURATION (REQUIRED)
# ===========================================
# Get your free Project ID from: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=ce79885351fb0b1e7a5f52d32209fafc

# ===========================================
# DEPRECATED: LEGACY MONGODB BACKEND (Optional)
# ===========================================
# Leave empty to use Firebase only (RECOMMENDED)
VITE_API_BASE=

# ===========================================
# OPTIONAL: APP CONFIGURATION
# ===========================================
VITE_APP_NAME=OnchainWeb
VITE_APP_URL=https://onchainweb.app

# ===========================================
# OPTIONAL: CLOUDFLARE TURN SERVER
# ===========================================
# For WebRTC connections - get from: https://dash.cloudflare.com/
# VITE_CLOUDFLARE_TURN_SERVER_NAME=
# VITE_CLOUDFLARE_TURN_TOKEN_ID=
# VITE_CLOUDFLARE_TURN_API_TOKEN=

# ===========================================
# OPTIONAL: TELEGRAM BOT INTEGRATION
# ===========================================
# VITE_TELEGRAM_BOT_TOKEN=
# VITE_TELEGRAM_CHAT_ID=

# ===========================================
# ADMIN CONFIGURATION (Optional but Recommended)
# ===========================================
# Enable admin and master routes
VITE_ENABLE_ADMIN=true

# Admin route paths
VITE_ADMIN_ROUTE=/admin
VITE_MASTER_ADMIN_ROUTE=/master-admin

# Comma-separated allowlisted admin emails
# Create these in Firebase Console > Authentication > Users first
VITE_ADMIN_ALLOWLIST=
